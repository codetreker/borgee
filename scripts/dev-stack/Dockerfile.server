# syntax=docker/dockerfile:1.7
# Borgee server (server-go) image for local e2e. Builds the Go server
# from packages/server-go + the React client from packages/client and
# bundles both into a small Debian runtime. CLIENT_DIST is wired to the
# bundled dist so the login UI is reachable end-to-end (Playwright
# clicks the real DOM, no curl bypass — see scripts/dev-stack/README
# pointer in docs/runbooks/local-e2e-helper-container.md).
#
# Build context = monorepo root:
#   docker build -f scripts/dev-stack/Dockerfile.server -t borgee-server:dev-stack .
#
# The compose file in this directory sets that context automatically.

FROM node:22-bookworm AS client-builder
WORKDIR /src
# pnpm version locked to 10, matching .github/workflows/ci.yml + deploy.yml
# (pnpm/action-setup@v4 version: 10). Floating to @latest breaks
# onlyBuiltDependencies semantics between versions (PR #694 testing fallout).
RUN corepack enable && corepack prepare pnpm@10 --activate
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/client/package.json packages/client/
RUN pnpm install --frozen-lockfile --filter @borgee/client
COPY packages/client packages/client
# Local-stack default: the helper talks to the server via the docker
# network name `borgee-server` on port 4900 (see docker-compose.yml).
# Override at build time when targeting a different layout.
ARG VITE_AGENT_WS_SERVER=ws://localhost:4900
ENV VITE_AGENT_WS_SERVER=${VITE_AGENT_WS_SERVER}
RUN pnpm --filter @borgee/client build

FROM golang:1.25-bookworm AS go-builder
WORKDIR /src/packages/server-go
# CGO + sqlite3 headers required by mattn/go-sqlite3.
RUN apt-get update \
 && apt-get install -y --no-install-recommends gcc libc6-dev sqlite3 libsqlite3-dev \
 && rm -rf /var/lib/apt/lists/*
COPY packages/server-go/go.mod packages/server-go/go.sum ./
RUN go mod download
COPY packages/server-go ./
RUN CGO_ENABLED=1 GOOS=linux go build -tags sqlite_fts5 -trimpath -ldflags="-s -w" -o /out/borgee-server ./cmd/collab

FROM debian:bookworm-slim AS runtime
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl sqlite3 libsqlite3-0 \
 && apt-get clean && rm -rf /var/lib/apt/lists/* \
 && useradd -r -u 10001 -g root borgee
WORKDIR /app
COPY --from=go-builder /out/borgee-server /usr/local/bin/borgee-server
COPY --from=client-builder /src/packages/client/dist /app/client/dist
RUN mkdir -p /var/lib/borgee-server/uploads /var/lib/borgee-server/workspace \
 && chown -R 10001:0 /var/lib/borgee-server /app/client
USER 10001
ENV HOST=0.0.0.0 \
    PORT=4900 \
    NODE_ENV=development \
    CLIENT_DIST=/app/client/dist \
    DATABASE_PATH=/var/lib/borgee-server/server.db \
    UPLOAD_DIR=/var/lib/borgee-server/uploads \
    WORKSPACE_DIR=/var/lib/borgee-server/workspace
EXPOSE 4900
ENTRYPOINT ["/usr/local/bin/borgee-server"]
