# Template for scripts/dev-stack/.env (LOCAL ONLY; .env is gitignored).
#
# Bring-up flow:
#   ./gen-keypair.sh > .env
#   cat .env.example | grep -v '^BORGEE_MANIFEST_SIGNING_KEY' >> .env
#   docker compose up -d
#
# The keypair generator writes the SIGNING_KEY (seed) + SIGNING_PUBKEY
# lines first; this file fills in everything else.

# Admin login — required by /admin-api/v1/* auth (internal/admin/auth.go).
# These env names are the locked literals from the review checklist.
BORGEE_ADMIN_LOGIN=admin
BORGEE_ADMIN_PASSWORD=local-e2e-admin-pwd

# JWT signing for user-rail tokens.
JWT_SECRET=local-e2e-jwt-secret-do-not-use-in-prod

# ed25519 seed for HB-1 manifest signing (set by gen-keypair.sh, do NOT
# hand-edit). Listed here as a placeholder for documentation only —
# gen-keypair.sh appends the real value as the very first line of .env
# before this block is concatenated in.
# BORGEE_MANIFEST_SIGNING_KEY=

# DB + working dirs inside the container (volume-backed).
DATABASE_PATH=/var/lib/borgee-server/server.db
UPLOAD_DIR=/var/lib/borgee-server/uploads
WORKSPACE_DIR=/var/lib/borgee-server/workspace

# Bind + UI runtime. NODE_ENV=development bypasses the prod-only
# CORS_ORIGIN check (internal/config/config.go Validate).
HOST=0.0.0.0
PORT=4900
NODE_ENV=development
CORS_ORIGIN=http://localhost:4900
CLIENT_DIST=/app/client/dist

# #1052 — origin stamped into the operator-facing `install_command`
# returned by POST /api/v1/helper/enrollments. The dev-stack publishes
# borgee-server on the host's loopback (`127.0.0.1:4900`) but the helper
# VM container reaches the server via the docker network DNS name
# `borgee-server:4900`. Without this override the UI would print
# `ws://127.0.0.1:4900` which is unreachable from inside borgee-vm. In
# production / single-host on-prem deploys leave this unset to keep the
# r.Host-derived behavior. Must start with ws:// or wss:// (no path).
BORGEE_PUBLIC_HELPER_ORIGIN=ws://borgee-server:4900

# #1050 blocker #3 — dev-stack manifest pipeline overrides.
#
# BORGEE_DEV_MANIFEST_ORIGIN_BASE: rewrites the openclaw artifact Origin
#   + Domains in the canonical signed helper-policy manifest from the
#   production placeholder https://cdn.borgee.io to this URL.
#   PURPOSE: lets the helper-vm container reach a real artifact endpoint
#   instead of the unprovisioned public CDN (#1003 follow-up).
#   When unset, the canonical manifest declares cdn.borgee.io as it
#   does in production. The manifest digest is derived from this value
#   at server boot, so changing this env var after the dev-stack is up
#   requires `docker compose restart borgee-server` to reseat helper jobs.
#
# BORGEE_DEV_MANIFEST_SHA256_OVERRIDE: JSON object mapping artifact_id
#   → sha256 hex. Lets dev-stack stamp the real sha256 of the sentinel
#   artifact in place of the production "0...0" placeholder. Unset →
#   placeholder preserved (same as production).
#
# A fully end-to-end install (UI click → binary written to
# /usr/local/lib/borgee/openclaw) still needs (a) a signed plugin
# manifest endpoint reachable from helper-vm at the origin base above
# and (b) the binary reachable at the BinaryURL the plugin manifest
# declares. That artifact-fixture pipeline is the work-in-progress
# half of blocker #3 — the env vars below are the stable contract;
# the fixture itself lives in a separate follow-up.
#BORGEE_DEV_MANIFEST_ORIGIN_BASE=http://borgee-server:4900/dev-artifacts
#BORGEE_DEV_MANIFEST_SHA256_OVERRIDE={"openclaw-plugin":"<sha256-hex>"}

# #1050 blocker #1 — dev-stack helper daemon outbound escape hatch.
# When set to "1", the helper daemon permits ws:// (and http://) to
# loopback / RFC1918 / single-label docker DNS hostnames (e.g.
# ws://borgee-server:4900). Production daemons leave this unset so
# the strict https/wss-only rule continues to bind. The same env var
# also gates the install_plugin executor's AllowInsecureManifest flag
# so http:// manifest URLs flow through to rootd in dev mode.
BORGEE_DEV_ALLOW_INSECURE_WS=1
