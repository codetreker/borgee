#!/bin/sh
# macOS preinstall script — runs before payload is laid down.
#
# Creates the `_borgee-helper` system user/group + Helper state directories
# that the LaunchDaemon's sandbox-exec profile expects to be writable.
# Idempotent: dscl create fails benignly with "already exists" which we mask.

set -eu

HELPER_USER="_borgee-helper"
HELPER_GROUP="_borgee-helper"
HELPER_HOME="/var/empty"
HELPER_SHELL="/usr/bin/false"

STATE_ROOT="/Library/Application Support/Borgee/Helper"
LOG_ROOT="/Library/Logs/Borgee"

# --- group ---
if ! dscl . -read "/Groups/$HELPER_GROUP" >/dev/null 2>&1; then
    # Pick first free GID in the 200..400 system range.
    NEW_GID=200
    while dscl . -list /Groups PrimaryGroupID 2>/dev/null | awk '{print $2}' | grep -qx "$NEW_GID"; do
        NEW_GID=$((NEW_GID + 1))
    done
    dscl . -create "/Groups/$HELPER_GROUP"
    dscl . -create "/Groups/$HELPER_GROUP" PrimaryGroupID "$NEW_GID"
    dscl . -create "/Groups/$HELPER_GROUP" RealName "Borgee Helper"
fi

# --- user ---
if ! dscl . -read "/Users/$HELPER_USER" >/dev/null 2>&1; then
    GID="$(dscl . -read "/Groups/$HELPER_GROUP" PrimaryGroupID | awk '{print $2}')"
    NEW_UID=200
    while dscl . -list /Users UniqueID 2>/dev/null | awk '{print $2}' | grep -qx "$NEW_UID"; do
        NEW_UID=$((NEW_UID + 1))
    done
    dscl . -create "/Users/$HELPER_USER"
    dscl . -create "/Users/$HELPER_USER" UniqueID "$NEW_UID"
    dscl . -create "/Users/$HELPER_USER" PrimaryGroupID "$GID"
    dscl . -create "/Users/$HELPER_USER" UserShell "$HELPER_SHELL"
    dscl . -create "/Users/$HELPER_USER" NFSHomeDirectory "$HELPER_HOME"
    dscl . -create "/Users/$HELPER_USER" RealName "Borgee Helper"
    dscl . -create "/Users/$HELPER_USER" Password '*'
fi

# --- state + log dirs ---
mkdir -p "$STATE_ROOT/QueueState" "$STATE_ROOT/StatusState" "$STATE_ROOT/AuditHandoff" "$LOG_ROOT"
chown -R "$HELPER_USER:$HELPER_GROUP" "$STATE_ROOT" "$LOG_ROOT"
chmod 0750 "$STATE_ROOT" "$STATE_ROOT/QueueState" "$STATE_ROOT/StatusState" "$STATE_ROOT/AuditHandoff" "$LOG_ROOT"

exit 0
