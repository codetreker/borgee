<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>cloud.borgee.host-bridge</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/sandbox-exec</string>
      <string>-f</string>
      <string>/Library/Application Support/Borgee/borgee-helper.sb</string>
      <string>/usr/local/bin/borgee-helper</string>
      <string>--socket=/Users/Shared/Borgee/borgee-helper.sock</string>
      <string>--audit-log=/Library/Logs/Borgee/audit.log.jsonl</string>
      <string>--grants-db=file:/Library/Application Support/Borgee/server.db?mode=ro&amp;_busy_timeout=5000</string>
      <string>--outbound-server-origin=https://app.borgee.io</string>
      <string>--outbound-allowed-origins=https://app.borgee.io</string>
      <string>--queue-state-dir=/Library/Application Support/Borgee/Helper/QueueState</string>
      <string>--status-state-dir=/Library/Application Support/Borgee/Helper/StatusState</string>
      <string>--audit-handoff-dir=/Library/Application Support/Borgee/Helper/AuditHandoff</string>
      <string>--enrollment-id-file=/Library/Application Support/Borgee/Helper/enrollment-id</string>
      <string>--helper-device-id-file=/Library/Application Support/Borgee/Helper/device-id</string>
      <string>--helper-credential-file=/Library/Application Support/Borgee/Helper/credential</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
      <key>SuccessfulExit</key>
      <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>UserName</key>
    <string>_borgee-helper</string>

    <key>GroupName</key>
    <string>_borgee-helper</string>

    <key>StandardOutPath</key>
    <string>/Library/Logs/Borgee/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Library/Logs/Borgee/stderr.log</string>
  </dict>
</plist>
