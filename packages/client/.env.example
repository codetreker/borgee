# Borgee client build-time env vars (Vite import.meta.env.VITE_*).
# Vite reads .env.example as documentation; CI builds inject real values
# via deploy workflows (deploy.yml / deploy-test.yml) before `pnpm build`.
#
# 0 hardcoded codetrek.cn in source — no-hardcoded-domain milestone.

# Remote agent ws server URL (agent --server flag in NodeManager UI).
# Per-env value:
#   - prod:    wss://borgee.codetrek.cn
#   - staging: wss://staging-borgee.codetrek.cn
#   - testing: wss://testing-borgee.codetrek.cn
#   - dev:     wss://localhost:4900 (local sandbox; default fallback when var unset)
VITE_AGENT_WS_SERVER=wss://borgee.codetrek.cn
